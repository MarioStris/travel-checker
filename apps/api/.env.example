# =============================================================================
# Travel Checker API — Environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ---- Server ---------------------------------------------------------------
PORT=3001
NODE_ENV=development

# ---- Database (Neon PostgreSQL) -------------------------------------------
# Local dev:  postgresql://postgres:postgres@localhost:5432/travel_checker
# Neon prod:  postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/travel_checker?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_checker"

# ---- Clerk Auth -----------------------------------------------------------
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Cloudflare R2 Storage ------------------------------------------------
# Account ID → Cloudflare Dashboard → R2 → Manage R2 API tokens
CLOUDFLARE_R2_ACCOUNT_ID="your_cloudflare_account_id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_r2_access_key_id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
CLOUDFLARE_R2_BUCKET_NAME="travel-checker-photos"
# Public URL of your R2 bucket (requires public access or custom domain)
CLOUDFLARE_R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# ---- Google Places API ----------------------------------------------------
# Cloud Console → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY="AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- CORS -----------------------------------------------------------------
# Comma-separated list of allowed origins (mobile app + web)
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:19006,exp://localhost:8081"

# ---- Sentry (optional — recommended for staging/production) ---------------
# Get from https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=""
