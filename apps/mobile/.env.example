# =============================================================================
# Travel Checker Mobile — Environment variables
# Copy this file to .env and fill in the values.
# All EXPO_PUBLIC_ variables are bundled into the app — do NOT put secrets here.
# NEVER commit .env to version control.
# =============================================================================

# ---- API ------------------------------------------------------------------
# Local dev:  http://localhost:3001
# Staging:    https://staging-api.travel-checker.app
# Production: https://api.travel-checker.app
EXPO_PUBLIC_API_URL=http://localhost:3001

# ---- Clerk Auth -----------------------------------------------------------
# Get from https://dashboard.clerk.com → API Keys → Publishable Key
# Use the pk_test_ key for development, pk_live_ for production
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Google Maps ----------------------------------------------------------
# Cloud Console → APIs & Services → Credentials
# Enable: Maps SDK for iOS, Maps SDK for Android, Places API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Feature flags (optional) ---------------------------------------------
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false
