# Travel Checker — Environment Variables
# Copy this file to .env and fill in your values

# === Database (Neon PostgreSQL) ===
DATABASE_URL="postgresql://user:password@host.neon.tech/travel_checker?sslmode=require"

# === Clerk Authentication ===
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

# === Clerk (Mobile — prefixed with EXPO_PUBLIC for client access) ===
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# === Google Maps / Places API ===
GOOGLE_PLACES_API_KEY="AIza..."
EXPO_PUBLIC_GOOGLE_MAPS_KEY="AIza..."

# === Cloudflare R2 (Photo Storage) ===
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="travel-checker-photos"
R2_CDN_URL="https://photos.travelchecker.app"

# === App Config ===
PORT=3001
NODE_ENV="development"
API_URL="http://localhost:3001"
EXPO_PUBLIC_API_URL="http://localhost:3001"

# === Sentry (Error Tracking, optional) ===
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
